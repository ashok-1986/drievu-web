late","children":"Identity & Contact Data:"}]," Your full name, professional email address, direct telephone number, and job title/role (e.g., Property Manager, Facilities Manager, Developer)."]}],["$","li",null,{"children":[["$","strong",null,{"className":"font-medium text-brand-slate","children":"Project & Property Specification Data:"}]," Building typology, approximate unit counts, physical site address, existing hardware setups, and system requirements submitted via our requirement forms."]}],["$","li",null,{"children":[["$","strong",null,{"className":"font-medium text-brand-slate","children":"Technical & Analytics Data:"}]," In accordance with our Phase 1 privacy rules, we deploy zero third-party advertising trackers. We may process anonymous, cookieless telemetry (such as page visits and viewport sizing) via privacy-first analytics tools to ensure site performance."]}]]}]]}],["$","div",null,{"className":"space-y-4","children":[["$","h2",null,{"className":"font-display font-medium text-xl md:text-2xl text-brand-slate tracking-tight border-b border-brand-grey/20 pb-3","children":"3. How We Use Your Information"}],["$","p",null,{"children":["We process your personal data under the lawful basis of ",["$","em",null,{"children":"contractual necessity"}]," and ",["$","em",null,{"children":"legitimate commercial interests"}]," for the following specific purposes:"]}],["$","ul",null,{"className":"list-disc pl-6 space-y-2 text-brand-slate/80","children":[["$","li",null,{"children":[["$","strong",null,{"className":"font-medium text-brand-slate","children":"Engineering Scoping & Surveys:"}]," To review your property requirements and contact you within our operational commitment of one working day to schedule a site survey."]}],["$","li",null,{"children":[["$","strong",null,{"className":"font-medium text-brand-slate","children":"System Design & Quoting:"}]," To engineer tailored proposals, storage calculations, and network diagrams for your building."]}],["$","li",null,{"children":[["$","strong",null,{"className":"font-medium text-brand-slate","children":"Contract & Maintenance Fulfillment:"}]," To execute installation testing, commissioning, and SLA-backed Annual Maintenance Contracts (AMC) once a project is awarded."]}]]}]]}],["$","div",null,{"className":"bg-brand-mist p-6 rounded-2xl border border-brand-grey/20 space-y-4","children":[["$","div",null,{"className":"flex items-center gap-2","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-lock w-5 h-5 text-brand-teal","children":[["$","rect","1w4ew1",{"width":"18","height":"11","x":"3","y":"11","rx":"2","ry":"2"}],["$","path","fwvmzm",{"d":"M7 11V7a5 5 0 0 1 10 0v4"}],"$undefined"]}],["$","h3",null,{"className":"font-display font-medium text-lg text-brand-slate tracking-tight","children":"4. CCTV & Surveillance Data Governance"}]]}],["$","p",null,{"className":"text-xs md:text-sm leading-relaxed text-brand-slate/85","children":"CCTV, video intercoms, and access control systems inherently process personal data (video footage and access logs). Drievu Limited designs and installs systems specified to UK GDPR requirements—incorporating appropriate privacy masking, encrypted credentials, and secure on-site NVR storage."}],["$","p",null,{"className":"text-xs md:text-sm leading-relaxed text-brand-slate/85","children":[["$","strong",null,{"children":"Important Governance Note:"}]," Upon completion of commissioning and documented handover, the client (Property Manager, Managing Agent, or Building Owner) becomes the statutory ",["$","em",null,{"children":"Data Controller"}]," for all operational CCTV footage and access logs captured on their premises. Every Drievu handover pack includes structured data-processing guidance and retention recommendations to assist controllers in maintaining continuous legal compliance."]}]]}],["$","div",null,{"className":"space-y-4","children":[["$","h2",null,{"className":"font-display font-medium text-xl md:text-2xl text-brand-slate tracking-tight border-b border-brand-grey/20 pb-3","children":"5. Data Security & Retention"}],["$","p",null,{"children":"We are committed to ensuring your information is secure. We have implemented robust technical and organizational measures to prevent unauthorized access, accidental loss, or disclosure."}],["$","p",null,{"children":"We retain client project specifications, engineering drawings, and contact records for the duration of any active warranty or Annual Maintenance Contract (AMC), plus a statutory accounting retention period of six years, after which records are securely archived or deleted."}]]}],["$","div",null,{"className":"space-y-4","children":[["$","h2",null,{"className":"font-display font-medium text-xl md:text-2xl text-brand-slate tracking-tight border-b border-brand-grey/20 pb-3","children":"6. Your Statutory Rights"}],["$","p",null,{"children":"Under the UK GDPR, you possess rights regarding your personal information, including:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-1 text-brand-slate/80 text-sm","children":[["$","li",null,{"children":[["$","strong",null,{"children":"The right to access:"}]," Request copies of personal data we hold about you."]}],["$","li",null,{"children":[["$","strong",null,{"children":"The right to rectification:"}]," Request correction of inaccurate or incomplete project records."]}],["$","li",null,{"children":[["$","strong",null,{"children":"The right to erasure:"}]," Request deletion of your lead data where ongoing contractual retention is not required."]}],["$","li",null,{"children":[["$","strong",null,{"children":"The right to restriction & objection:"}]," Object to or restrict the processing of your contact details for marketing communications."]}]]}],["$","p",null,{"className":"text-sm pt-2","children":["To exercise any of these statutory ri